{
  "name": "typewriter",
  "version": "0.0.0",
  "private": true,
  "description": "Generate Elm types and decoders from Zod schemas",
  "type": "module",
  "author": "John Pavlick",
  "license": "ISC",
  "scripts": {
    "generate": "tsx index.ts",
    "test": "pnpm test:unit && elm-test && pnpm test:ts",
    "test:unit": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:ts": "pnpm typecheck && tsx index.ts",
    "test:elm:watch": "elm-test --watch --no-clear-console",
    "test:ts:watch": "chokidar \"tsconfig.json\" \"*.ts\" \"codegen/**/*\" \"lib/**/*\" \"src/**/*\" \"tests/**/*\" -c \"pnpm test:ts\"",
    "test:watch": "concurrently \"pnpm test:elm:watch\" \"pnpm test:ts:watch\"",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/node": "^25.1.0",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "elm-test": "0.19.1-revision17",
    "elm-tooling": "^1.17.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "elm": "0.19.1-6",
    "elm-codegen": "^0.6.3",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
